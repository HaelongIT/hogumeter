# 루트 .env로 복사해 값 채움 (.env는 gitignore — 절대 커밋 금지)
DB_NAME=hogumeter
DB_USER=hogumeter
DB_PASSWORD=change-me

# 호스트 포트 (전부 127.0.0.1에만 바인딩). 이미 쓰는 포트가 있으면 비켜간다 —
# 포트 하나가 스택 전체의 기동을 막으면 안 된다.
POSTGRES_PORT=5432
CORE_PORT=8080
WEB_PORT=3000

# HTTPS 종단(D-4, SEC-02 나머지). Caddy가 이 도메인으로 Let's Encrypt를 자동 발급·갱신한다.
# 비우면(기본 localhost) Caddy 내부 CA의 자체서명 인증서 — 로컬 리허설용, 브라우저 경고가 뜬다.
# caddy 서비스는 `public` 프로파일이라 `docker compose --profile public up -d`로 명시해야
# 뜬다(기본 up -d로는 안 뜸). 공개망에 실제로 열려면 DOMAIN + 서버의 80/443 방화벽을
# 사람이 먼저 준비한다(pre-deploy-checklist.md).
DOMAIN=

# web 접근 통제 (SEC-02). 비우면 Basic Auth 꺼짐 — 로컬(127.0.0.1) 전용.
# 공개망에 노출하려면 반드시 채운다. 평문이 아니라 htpasswd 해시 한 줄:
#   docker run --rm httpd:2.4-alpine htpasswd -nbm hogu '비밀번호'
# 결과 예: hogu:$apr1$abc123$XyZ...   (compose에 넣을 땐 $를 $$로 이스케이프)
WEB_BASIC_AUTH_HTPASSWD=

# 수집기 실 네트워크 폴링 스위치 (기본 off)
# 1로 켜야 collector가 핫딜 3사에 실제로 요청을 보낸다. 켜기 전 pre-deploy-checklist §F 확인:
#   - 3사 robots.txt 실 대조 (RobotsGate는 fake opener 테스트만 통과했다)
#   - 차단당한 사이트를 되살릴 방법이 아직 없다 (decisions-needed D-3)
COLLECTOR_ALLOW_NETWORK=0

# 텔레그램 봇 (M1, AL-05)
# 실 발송 스위치. 비우면(기본) 스텁 — 실 발송이 절대 안 일어난다(개발·CI 안전). true로 켜야 실 어댑터가
# 뜨고, 그때 아래 토큰·chat_id가 반드시 있어야 한다(없으면 기동 실패로 설정 누락을 드러낸다).
TELEGRAM_ENABLED=
TELEGRAM_BOT_TOKEN=
# 알림이 나갈 대상 chat_id(아웃바운드). @BotFather로 봇을 만들고, 봇과 대화를 시작한 뒤
# https://api.telegram.org/bot<토큰>/getUpdates 로 내 chat_id를 확인해 넣는다.
TELEGRAM_CHAT_ID=
# SEC-03(인바운드): 봇이 **명령을 받아들일** chat_id 화이트리스트. 인라인 버튼 승격(Q-15 후속)이 생길 때
# 그 콜백을 이 목록으로 거른다 — 토큰만 있고 이게 비면 누구든 봇에게 명령을 보낼 수 있다(docs/91 Q-61).
# 아웃바운드(위 TELEGRAM_CHAT_ID)와 별개다. 아직 인바운드 핸들러가 없어 소비되지 않는다.
TELEGRAM_ALLOWED_CHAT_IDS=

# 네이버 쇼핑 API (발급 전 — docs/91 Q-3)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 쿠팡 크롬 확장 ingest 고정 토큰(CMP-02, SEC-04). 확장이 이 값을 요청 헤더(X-Extension-Token)에
# 실어 보낸다. 비우면(기본) 그 엔드포인트는 모든 요청을 거절한다 — 열어두지 않는다.
EXTENSION_INGEST_TOKEN=

# ── 오프사이트 백업 (REL-04) — 비워두면 업로드를 건너뛰고 "오프사이트 없음"을 출력한다.
# 로컬 디스크가 죽으면 백업도 함께 죽으므로 운영에선 채운다. IAM은 해당 prefix에
# PutObject/GetObject/HeadObject만 부여. 리허설: bash scripts/offsite-drill.sh
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=postgres
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-2
# S3 호환 스토리지를 쓸 때만(MinIO 등). 비면 실 AWS.
BACKUP_S3_ENDPOINT=

# 파이프라인 트리거 주기(ms). core가 raw_deal_post를 deal_event로 변환하는 주기.
# 게시판 폴링 하한이 60s라 기본 60000이면 충분하다. 낮추면 DB 부하만 는다.
CORE_PIPELINE_INTERVAL_MS=60000

# OBS-01 core 로그 형식. ecs(기본) / logstash / gelf. 빈 값이면 구조화를 끈다(텍스트 로그).
# compose가 `${CORE_LOG_FORMAT-ecs}`로 읽는다 — 미설정이면 ecs, 빈 값이면 빈 값이 그대로 간다.
# (`:-`였다면 빈 값에도 기본값이 붙어 절대 끌 수 없다. `docker compose config`로 실측 확인.)
# collector는 항상 JSON Lines다. 두 컨테이너를 한 곳에서 읽으려면 core도 JSON이어야 한다.
CORE_LOG_FORMAT=ecs
